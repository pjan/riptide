{
  "manifest_version": 3,
  "name": "skiff",
  "version": "1.0.0",
  "description": "Sail the riptide",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://*/", "https://*/"],
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html"
}
